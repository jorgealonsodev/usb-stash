{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for USB Stash — no network, filesystem restricted to cwd",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$CWD/**" }
      ]
    }
  ]
}
